{
  "target": "esp32_devkitc_idf",
  "board": "ESP32-WROOM-32",
  "backend": "esp_idf",
  "cc": {
    "name": "ESP-IDF",
    "path": "python idf.py",
    "args": [
      "set-target esp32",
      "build"
    ]
  },
  "flasher": {
    "name": "ESP-IDF",
    "path": "python idf.py",
    "args": "flash"
  },
  "api_paths": [
    "espressif/esp32_devkitc_idf",
    "espressif/esp_idf/core"
  ],
  "v_defines": [],
  "default_cpu_freq": 4000000,
  "default_string_len": 50,
  "compiler_setup_path": "setup/esp_idf.json"
}